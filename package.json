{
  "name": "efort-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost",
    "dev:demo": "VITE_TASKS_BACKEND=mock vite",
    "build": "vite build",
    "build:hosting": "VITE_TASKS_BACKEND=firebase vite build",
    "preview": "vite preview",
    "test": "node --test src/athleteTypeDistribution.test.js",
    "deploy:functions": "firebase deploy --only functions --project efort-app",
    "deploy:hosting": "npm run build:hosting && firebase deploy --only hosting --project efort-app",
    "poll:queued-runs": "node scripts/poll_queued_runs.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "chart.js": "^4.4.3",
    "firebase": "^10.12.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "supabase": "^2.78.1",
    "vite": "^5.4.0"
  }
}
